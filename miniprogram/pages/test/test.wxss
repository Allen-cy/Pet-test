.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #fcf9f4;
  padding: 40rpx;
}

.header {
  margin-top: 120rpx;
}

.progress-text {
  font-size: 22rpx;
  color: rgba(28, 28, 25, 0.6);
  margin-bottom: 16rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: rgba(28, 28, 25, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #72553d;
  border-radius: 4rpx;
  transition: width 0.5s ease-out;
}

.question-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.question-text {
  font-size: 40rpx;
  text-align: center;
  color: #1c1c19;
  line-height: 1.5;
}

.options-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  background-color: #f6f3ee;
  border: 2rpx solid rgba(28, 28, 25, 0.1);
  border-radius: 24rpx;
}

.option-item.selected {
  background-color: rgba(232, 201, 160, 0.2);
  border-color: #72553d;
}

.option-letter {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(28, 28, 25, 0.1);
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: bold;
  color: rgba(28, 28, 25, 0.6);
}

.option-item.selected .option-letter {
  background-color: #72553d;
  color: white;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #1c1c19;
}

.finish-section {
  margin-top: auto;
  padding-bottom: 40rpx;
}

.finish-btn {
  width: 100%;
  padding: 28rpx;
  background-color: #72553d;
  color: white;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}
