.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(180deg, #fcf9f4 0%, #f6f3ee 100%);
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 60rpx;
}

.paw-icon {
  font-size: 40rpx;
  color: #72553d;
}

.brand-text {
  font-size: 32rpx;
  color: #72553d;
  font-weight: 500;
}

.image-section {
  position: relative;
  width: 384rpx;
  height: 384rpx;
  margin-bottom: 60rpx;
}

.main-image-wrapper {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  left: 0;
  top: 0;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
}

.main-image {
  width: 100%;
  height: 100%;
}

.sub-image-wrapper {
  position: absolute;
  width: 144rpx;
  height: 144rpx;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.sub-image {
  width: 100%;
  height: 100%;
}

.content-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1c1c19;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(28, 28, 25, 0.6);
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto;
  padding-bottom: 80rpx;
}

.stat-text {
  font-size: 22rpx;
  color: rgba(28, 28, 25, 0.4);
  margin-bottom: 40rpx;
}

.start-btn {
  width: 100%;
  padding: 28rpx;
  background-color: #72553d;
  color: white;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}
