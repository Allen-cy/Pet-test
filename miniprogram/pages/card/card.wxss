.container {
  min-height: 100vh;
  background-color: #fcf9f4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.card-wrapper {
  width: 320px;
  height: 520px;
  border-radius: 72rpx;
  overflow: hidden;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.3);
  margin-bottom: 40rpx;
}

.buttons {
  display: flex;
  gap: 24rpx;
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 30rpx;
}

.btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.btn.save {
  background-color: #2a2a2a;
  color: white;
}

.btn.share {
  background-color: #E8C9A0;
  color: #1c1c19;
}

.restart {
  color: rgba(28, 28, 25, 0.4);
  font-size: 26rpx;
  padding: 20rpx;
}
